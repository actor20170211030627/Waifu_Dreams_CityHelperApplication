<Page x:Class="Waifu_Dreams_CityHelperApplication.Pages.Build_101_Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Waifu_Dreams_CityHelperApplication.Pages"
      mc:Ignorable="d"
      Height="Auto"
      Width="Auto">
    <StackPanel Orientation="Vertical">
        <!--Top-->
        <DockPanel
            Background="LightSkyBlue"
            Height="Auto">
            <TextBlock
                Foreground="White"
                FontSize="13"
                TextAlignment="Center"
                Text="游戏运行状态&#x0A;(Game running state):"
                Margin="5,5" />
            <Border
                Name="Border_Running"
                Height="Auto"
                Width="Auto"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                BorderThickness="1"
                BorderBrush="Green"
                Background="ForestGreen"
                CornerRadius="10">
                <TextBlock
                    Text="✅运行中"
                    Padding="5 2 5 2"
                    Foreground="White" />
            </Border>
            <Border
                Name="Border_Stopped"
                Height="Auto"
                Width="Auto"
                VerticalAlignment="Center"
                BorderThickness="1"
                BorderBrush="DarkRed"
                Background="Red"
                CornerRadius="10">
                <TextBlock
                    Text="❌未发现游戏"
                    Padding="5 2 5 2"
                    Foreground="White" />
            </Border>

            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Right">
                <TextBlock
                    Foreground="White"
                    Margin="0 0 10 0"
                    TextAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="13">
                    激活修改器(TRainer activate)<LineBreak />
                    <Image
                        Name="Image_TRainer_State"
                        Width="35" Height="Auto"
                        MouseLeftButtonDown="Btn_OnClick"
                        Source="/Resources/Images/icon_switch_green2.png" />
                </TextBlock>
                <Button
                    Name="Btn_About"
                    Width="80"
                    Height="22"
                    Click="Btn_OnClick"
                    Margin="0 0 2 0"
                    Content="关于(About)" />
            </StackPanel>
        </DockPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- rows = 9 -->
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />

                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Image
                Grid.Row="0"
                Grid.Column="0"
                Grid.RowSpan="10"
                Width="150"
                Source="/Resources/Images/waifu-dreams-city.jpg" />

            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                Foreground="Red"
                TextAlignment="Center"
                VerticalAlignment="Center"
                Text="项目(Property)" />
            <TextBlock
                Grid.Row="0"
                Grid.Column="3"
                Foreground="Red"
                VerticalAlignment="Center"
                Text="当前值(Value)">
                <!-- 当前值&#x0A;(Value) -->
            </TextBlock>
            <TextBlock
                Grid.Row="0"
                Grid.Column="4"
                Margin="5 0 0 0"
                TextAlignment="Center"
                Foreground="Red"
                VerticalAlignment="Center"
                Text="点击加点(Click2+)" />
            <TextBlock
                Grid.Row="0"
                Grid.Column="5"
                Margin="5 0 0 0"
                TextAlignment="Center"
                Foreground="Red"
                VerticalAlignment="Center"
                Text="冻结当前值(Freeze)" />


            <Image
                Grid.Row="1"
                Grid.Column="1"
                Width="Auto" Height="20"
                Source="/Resources/Images/money_dollar.png" />
            <TextBlock
                Grid.Row="1"
                Grid.Column="2"
                Text="钱(Money):"
                Margin="1" />
            <TextBlock
                Name="TB_Money"
                Grid.Row="1"
                Grid.Column="3"
                Padding="1 0 0 0"
                Text="100" />
            <Button
                Name="Btn_Money"
                Grid.Row="1"
                Grid.Column="4"
                Click="Btn_OnClick"
                Content="+1000w" />


            <Image
                Grid.Row="2"
                Grid.Column="1"
                Width="Auto" Height="20"
                Source="/Resources/Images/Level.png" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="2"
                Text="人物等级(Level):"
                Margin="1" />
            <TextBlock
                Name="TB_Level"
                Grid.Row="2"
                Grid.Column="3"
                Padding="1 0 0 0"
                Text="100" />
            <Button
                Name="Btn_Level"
                Grid.Row="2"
                Grid.Column="4"
                Click="Btn_OnClick"
                Content="+2" />


            <Image
                Grid.Row="3"
                Grid.Column="1"
                Width="Auto" Height="20"
                Source="/Resources/Images/HookerLips.png" />
            <TextBlock
                Grid.Row="3"
                Grid.Column="2"
                Text="魅力值(Charm):"
                Margin="1" />
            <TextBlock
                Name="TB_Charm"
                Grid.Row="3"
                Grid.Column="3"
                Padding="1 0 0 0"
                Text="100" />
            <Button
                Name="Btn_Charm"
                Grid.Row="3"
                Grid.Column="4"
                Click="Btn_OnClick"
                Content="+1000" />


            <Border
                Grid.Row="4"
                Grid.Column="1"
                Width="Auto" Height="20"
                Margin="1.5"
                BorderThickness="1"
                CornerRadius="1 5 5 1"
                BorderBrush="Black">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#004760" Offset="0.0" />
                        <GradientStop Color="#004760" Offset="0.5" />
                        <GradientStop Color="#004760" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <TextBlock
                Grid.Row="4"
                Grid.Column="2"
                TextAlignment="Center"
                Text="性饥渴&#x0A;(Sexual Hunger)"
                Margin="1" />
            <Image
                Grid.Row="4"
                Grid.Column="5"
                Name="Image_Freeze_Sexual_Hunger"
                Width="35" Height="Auto"
                HorizontalAlignment="Left"
                Margin="15 0 0 0"
                MouseLeftButtonDown="Btn_OnClick"
                Source="/Resources/Images/icon_switch_lightyellow.png" />
        </Grid>
    </StackPanel>
</Page>